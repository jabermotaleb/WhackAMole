@{
    ViewData["Title"] = "Whack-a-Mole";
}

<div class="container text-center py-4">

    <h1 class="mb-2">🔨 Whack-a-Mole</h1>
    <p class="text-muted">Click the moles before they disappear!</p>

    <!-- Score and Timer -->
    <div class="d-flex justify-content-center gap-4 mb-4">
        <div class="card px-4 py-2">
            <div class="fw-bold text-muted small">SCORE</div>
            <div class="fs-3 fw-bold" id="score">0</div>
        </div>
        <div class="card px-4 py-2">
            <div class="fw-bold text-muted small">TIME</div>
            <div class="fs-3 fw-bold" id="timer">30</div>
        </div>
    </div>

    <!-- Game Board -->
    <div class="game-board mx-auto mb-4">
        <div class="hole" id="hole0"><div class="mole" id="mole0" onclick="whack(0)">🐹</div></div>
        <div class="hole" id="hole1"><div class="mole" id="mole1" onclick="whack(1)">🐹</div></div>
        <div class="hole" id="hole2"><div class="mole" id="mole2" onclick="whack(2)">🐹</div></div>
        <div class="hole" id="hole3"><div class="mole" id="mole3" onclick="whack(3)">🐹</div></div>
        <div class="hole" id="hole4"><div class="mole" id="mole4" onclick="whack(4)">🐹</div></div>
        <div class="hole" id="hole5"><div class="mole" id="mole5" onclick="whack(5)">🐹</div></div>
        <div class="hole" id="hole6"><div class="mole" id="mole6" onclick="whack(6)">🐹</div></div>
        <div class="hole" id="hole7"><div class="mole" id="mole7" onclick="whack(7)">🐹</div></div>
        <div class="hole" id="hole8"><div class="mole" id="mole8" onclick="whack(8)">🐹</div></div>
    </div>

    <!-- Start Button -->
    <button class="btn btn-success btn-lg px-5" id="startBtn" onclick="startGame()">Start Game</button>

    <!-- Game Over Message -->
    <div id="gameOver" class="mt-4" style="display:none">
        <h3>Game Over!</h3>
        <p class="fs-5">Your score: <strong id="finalScore">0</strong></p>
        <button class="btn btn-primary" onclick="startGame()">Play Again</button>
    </div>

</div>
