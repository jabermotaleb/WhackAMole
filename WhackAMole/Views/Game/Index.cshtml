@{ ViewData["Title"] = "Whack-a-Mole"; }

<div class="container py-4">

    <!-- Header -->
    <div class="text-center mb-4">
        <h1 class="display-5 fw-bold">🔨 Whack-a-Mole</h1>
        <p class="text-muted">Whack as many moles as you can before time runs out!</p>
    </div>

    <!-- Stats Bar -->
    <div class="row g-3 mb-4 justify-content-center">
        <div class="col-4 col-md-3">
            <div class="card bg-secondary text-center p-3">
                <div class="fs-3 fw-bold text-warning" id="scoreDisplay">0</div>
                <div class="small text-muted">Score</div>
            </div>
        </div>
        <div class="col-4 col-md-3">
            <div class="card bg-secondary text-center p-3">
                <div class="fs-3 fw-bold text-info" id="timeDisplay">30</div>
                <div class="small text-muted">Time</div>
            </div>
        </div>
        <div class="col-4 col-md-3">
            <div class="card bg-secondary text-center p-3">
                <div class="fs-3 fw-bold text-success" id="levelDisplay">1</div>
                <div class="small text-muted">Level</div>
            </div>
        </div>
    </div>

    <!-- Game Board -->
    <div class="game-board mx-auto mb-4" id="gameBoard">
        @for (int i = 0; i < 9; i++)
        {
            <div class="hole" id="hole-@i">
                <div class="mole" id="mole-@i">🐹</div>
            </div>
        }
    </div>

    <!-- Controls -->
    <div class="text-center mb-4">
        <button class="btn btn-success btn-lg px-5 me-2" id="startBtn" onclick="startGame()">
            <i class="bi bi-play-fill me-2"></i>Start Game
        </button>
        <button class="btn btn-outline-light btn-lg" onclick="showLeaderboard()">
            <i class="bi bi-trophy me-2"></i>Leaderboard
        </button>
    </div>

    <!-- Difficulty -->
    <div class="text-center mb-4">
        <span class="text-muted me-2">Difficulty:</span>
        <div class="btn-group" id="diffBtns">
            <button class="btn btn-sm btn-outline-success active" onclick="setDiff('easy',this)">Easy</button>
            <button class="btn btn-sm btn-outline-warning" onclick="setDiff('medium',this)">Medium</button>
            <button class="btn btn-sm btn-outline-danger" onclick="setDiff('hard',this)">Hard</button>
        </div>
    </div>

    <!-- Leaderboard -->
    <div class="card bg-secondary mx-auto mb-4" style="max-width:400px;display:none" id="leaderboardCard">
        <div class="card-header fw-bold"><i class="bi bi-trophy-fill text-warning me-2"></i>Leaderboard</div>
        <div class="card-body p-0">
            <table class="table table-dark table-sm mb-0">
                <thead><tr><th>#</th><th>Name</th><th>Score</th><th>Date</th></tr></thead>
                <tbody id="leaderboardBody"></tbody>
            </table>
            <div class="text-center text-muted p-3" id="noScores" style="display:none">No scores yet. Play a game!</div>
        </div>
    </div>

</div>

<!-- Game Over Modal -->
<div class="modal fade" id="gameOverModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-dark text-white">
            <div class="modal-header border-secondary">
                <h5 class="modal-title fw-bold">🎉 Game Over!</h5>
            </div>
            <div class="modal-body text-center">
                <div class="fs-1 fw-bold text-warning mb-2" id="finalScore">0</div>
                <p class="text-muted mb-3">Enter your name to save your score</p>
                <input type="text" class="form-control bg-secondary text-white border-secondary text-center mb-3"
                       id="playerName" placeholder="Your name" maxlength="20" />
                <div id="rankMsg" class="text-success fw-semibold mb-2" style="display:none"></div>
            </div>
            <div class="modal-footer border-secondary justify-content-center">
                <button class="btn btn-warning px-4" onclick="saveScore()">
                    <i class="bi bi-save me-2"></i>Save Score
                </button>
                <button class="btn btn-outline-light px-4" onclick="playAgain()">
                    <i class="bi bi-arrow-repeat me-2"></i>Play Again
                </button>
            </div>
        </div>
    </div>
</div>
